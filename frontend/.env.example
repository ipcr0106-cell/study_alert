# 이 파일을 복사해 `.env`로 저장한 뒤 값을 채우세요. `.env`는 git에 포함되지 않습니다.
# 실행/APK: flutter run / flutter build apk ... 모두
#   --dart-define-from-file=.env  한 번이면 됨 (아래 API_BASE_URL 포함 시)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
API_BASE_URL=https://your-service.onrender.com
